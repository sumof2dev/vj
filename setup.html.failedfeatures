    <script>
        // --- STATE ---
        // Global Error Handler for Mobile/Remote Debugging
        window.onerror = function (msg, url, lineNo, columnNo, error) {
            alert(`[JS ERROR] ${msg}\nLine: ${lineNo}\nColumn: ${columnNo}\n${error ? error.stack : ''}`);
            return false;
        };
        window.onunhandledrejection = function (event) {
            alert(`[ASYNC ERROR] ${event.reason}`);
        };

        const API_BASE = localStorage.getItem('vj_backend_url') || '/api/fixtures';
        let stageConfig = { devices: {} };
        let currentProfile = null;
        let availableProfiles = [];
        let ws = null;
        let latestDmxState = {};
        let activeLiveTesters = {}; // Key: role, Value: { devName: string, data: [], raf: int }
        let liveTesterMaxFrames = 60 * 30; // 30 seconds at 60fps

        // Fixture Setup Enhancements State
        let activeTestDevices = []; // Array of devNames
        let testProfiles = {}; // Key: type, Value: Profile object
        let testOrder = {}; // Key: devName, Value: Array of absAddr
        let linkedLinks = {}; // Key: devName, Value: Set of linked pairs (e.g. "addr1-addr2")
        let saveActiveChannels = {};
        let currentFaderValues = {};
        let looperState = {};
        let looperInterval = null;
        let isEngineVisualOn = true;
        let draggingAddresses = new Set();

        // --- INIT ---
        async function init() {
            await loadStageConfig();
            await loadProfileList();
            connectWs();
            renderPresetsManager();
        }

        const BIN_LABELS = [
            "0: Sub-Bass (Heavy Kicks/808)",
            "1: Bass & Low-Mid (Basslines/Warmth)",
            "2: Mid & Upper-Mid (Vocals/Synths)",
            "3: Presence (High Vocals/Claps)",
            "4: Treble (Percussion/Hats)",
            "5: Air (Cymbals/Sizzle)"
        ];



        // --- NAVIGATION ---
        function showView(viewId) {
            document.querySelectorAll('.view-panel').forEach(el => el.classList.remove('active'));
            document.getElementById('view-' + viewId).classList.add('active');
            document.querySelectorAll('.nav-btn').forEach(el => el.classList.remove('active'));
            event.currentTarget.classList.add('active');
        }

        // --- STAGE MANAGER ---
        async function loadStageConfig() {
            try {
                const res = await fetch(`${API_BASE}/stage_config.json`);
                if (!res.ok) throw new Error("No stage config");
                stageConfig = await res.json();

                if (!stageConfig.devices) stageConfig.devices = {};
                if (stageConfig.lasers) {
                    Object.assign(stageConfig.devices, stageConfig.lasers);
                    delete stageConfig.lasers;
                }

                renderDevices();
                populateTestDevices();
            } catch (e) {
                console.error(e);
                stageConfig = { devices: {} };
            }
        }

        async function saveStageConfig() {
            try {
                const res = await fetch(`${API_BASE}/stage_config.json`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(stageConfig, null, 4)
                });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                alert('Stage Configuration Saved!');
            } catch (e) {
                alert(`Error saving layout: ${e.message}`);
            }
        }

        function renderDevices() {
            const list = document.getElementById('device-list');
            list.innerHTML = '';

            const profiles = availableProfiles.map(f => f.replace('.json', ''));

            Object.entries(stageConfig.devices || {}).forEach(([key, dev]) => {
                const row = document.createElement('div');
                row.className = 'device-row';
                row.innerHTML = `
                <div style="display:flex; justify-content:space-between; width:100%; align-items:center;">
                    <div style="flex:1; display:flex; align-items:center; gap:8px;">
