        function toggleEngineVisual() {
            const track = document.getElementById('engine-toggle');
            isEngineVisualOn = !isEngineVisualOn;
            
            if (isEngineVisualOn) {
                if (track) track.classList.add('on');
                // Clear overrides for all active test devices to return control to the engine
                if (ws && ws.readyState === 1) {
                    activeTestDevices.forEach(devName => {
                        ws.send(JSON.stringify({ type: 'clear_overrides', device: devName }));
                    });
                }
            } else {
                if (track) track.classList.remove('on');
