            if (activeLiveTesters[role]) {
                activeLiveTesters[role].devName = devName;
                activeLiveTesters[role].data = []; // Clear old data
            }
        }

        function startLiveTesterLoop(role) {
            function loop() {
                if (!activeLiveTesters[role]) return;

                const tester = activeLiveTesters[role];
                const stateKey = `${tester.devName}_${role}`;
                const val = latestDmxState[stateKey] !== undefined ? latestDmxState[stateKey] : 0;

                // Update data buffer
                tester.data.push(val);
                if (tester.data.length > liveTesterMaxFrames) tester.data.shift();

                // Update numerical display
                const valEl = document.getElementById(`live-val-${role}`);
                if (valEl) valEl.innerText = val;

                // Draw Waveform
                const canvas = document.getElementById(`live-canvas-${role}`);
                if (canvas) {
                    if (canvas.width !== canvas.clientWidth) canvas.width = canvas.clientWidth;
                    if (canvas.height !== canvas.clientHeight) canvas.height = canvas.clientHeight;

                    const ctx = canvas.getContext('2d');
                    const w = canvas.width;
                    const h = canvas.height;

                    ctx.clearRect(0, 0, w, h);

                    // Grid lines
                    ctx.beginPath();
                    ctx.strokeStyle = '#1a1a1a';
                    ctx.lineWidth = 1;
                    // Horizontal Grid (DMX steps)
                    for (let i = 1; i < 4; i++) {
                        const gy = (h / 4) * i;
                        ctx.moveTo(0, gy); ctx.lineTo(w, gy);
                    }
                    // Vertical Grid (Time marks - 10s intervals)
                    for (let i = 1; i < 3; i++) {
                        const gx = (w / 3) * i;
                        ctx.moveTo(gx, 0); ctx.lineTo(gx, h);
                    }
                    ctx.stroke();

                    if (tester.data.length > 1) {
                        const xStep = w / liveTesterMaxFrames;
                        const offset = liveTesterMaxFrames - tester.data.length;

                        // 1. Draw Fill Area
                        ctx.beginPath();
                        const fillGrad = ctx.createLinearGradient(0, 0, 0, h);
                        fillGrad.addColorStop(0, 'rgba(124, 77, 255, 0.2)');
                        fillGrad.addColorStop(1, 'rgba(124, 77, 255, 0)');
                        ctx.fillStyle = fillGrad;

                        for (let i = 0; i < tester.data.length; i++) {
                            const px = (i + offset) * xStep;
                            const py = h - ((tester.data[i] / 255) * (h - 4)) - 2;
                            if (i === 0) ctx.moveTo(px, py);
                            else ctx.lineTo(px, py);
                        }

                        // Close path for fill
                        const lastX = (tester.data.length - 1 + offset) * xStep;
                        ctx.lineTo(lastX, h);
                        ctx.lineTo(offset * xStep, h);
                        ctx.closePath();
                        ctx.fill();

                        // 2. Draw Main Waveform Line
                        ctx.beginPath();
                        ctx.strokeStyle = '#7c4dff';
                        ctx.lineWidth = 2.5;
                        ctx.lineJoin = 'round';
                        ctx.shadowBlur = 8;
                        ctx.shadowColor = 'rgba(124, 77, 255, 0.5)';

                        for (let i = 0; i < tester.data.length; i++) {
                            const px = (i + offset) * xStep;
                            const py = h - ((tester.data[i] / 255) * (h - 4)) - 2;
                            if (i === 0) ctx.moveTo(px, py);
                            else ctx.lineTo(px, py);
                        }
                        ctx.stroke();
                        ctx.shadowBlur = 0; // Reset for playhead

                        // 3. Playhead
                        const lastVal = tester.data[tester.data.length - 1];
                        const lastPx = (tester.data.length - 1 + offset) * xStep;
                        const lastPy = h - ((lastVal / 255) * (h - 4)) - 2;

                        ctx.beginPath();
                        ctx.fillStyle = '#fff';
                        ctx.arc(lastPx, lastPy, 4, 0, Math.PI * 2);
                        ctx.fill();

                        // Horizontal current line
                        ctx.beginPath();
                        ctx.setLineDash([5, 5]);
                        ctx.strokeStyle = 'rgba(255,255,255,0.2)';
                        ctx.moveTo(0, lastPy);
                        ctx.lineTo(w, lastPy);
                        ctx.stroke();
                        ctx.setLineDash([]);
                    }
                }

                tester.raf = requestAnimationFrame(loop);
            }

            activeLiveTesters[role].raf = requestAnimationFrame(loop);
        }

        window.onload = init;

        // PWA Service Worker Registration
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('sw.js')
                    .then(reg => console.log('SW Registered', reg.scope))
                    .catch(err => console.log('SW Failed', err));
            });
        }
    </script>
