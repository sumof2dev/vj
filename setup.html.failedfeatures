        async function zeroDeviceDmx(devName) {
            let allDevices = stageConfig.devices || {};
            const dev = allDevices[devName];
            if (!dev) return;

            let profile = testProfiles[dev.type];
            if (!profile) {
                try {
                    const res = await fetch(`${API_BASE}/${dev.type}.json`);
                    if (res.ok) {
                        profile = await res.json();
                        testProfiles[dev.type] = profile;
                    } else return;
                } catch (e) { console.error("Profile load error", e); return; }
            }

            if (!profile || !profile.channels) return;

            Object.entries(profile.channels).forEach(([role, val]) => {
                const offset = typeof val === 'object' ? val.offset : val;
                const absAddr = dev.address + dev.offset + offset;

                currentFaderValues[absAddr] = 0;
                saveActiveChannels[absAddr] = true; // Mark as overridden

                const disp = document.getElementById(`disp-${absAddr}`);
                if (disp) {
                    disp.value = 0;
                    disp.innerText = 0;
                }
                const input = document.getElementById(`input-${absAddr}`);
                if (input) input.value = 0;
                const checkbox = document.getElementById(`save-active-${absAddr}`);
                if (checkbox) checkbox.checked = true;

                updateDmxState(absAddr, 0, false, true); // skipLinked=false, skipAutoCheck=true
            });
        }

        function toggleLooper(addr) {
            if (!looperState[addr]) looperState[addr] = { mode: 'paused', frames: [], playIdx: 0, lastVal: currentFaderValues[addr] || 0 };

            const state = looperState[addr];
            const btn = document.getElementById(`looper-btn-${addr}`);

            if (state.mode === 'playing') {
                state.mode = 'paused';
                if (btn) btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>'; // Show Play icon when paused
                // Set channel to 0 immediately when pausing
                updateDmxState(parseInt(addr), 0, true, true);
            } else {
                state.mode = 'playing';
                if (btn) btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M6 4h4v16H6zm8 0h4v16h-4z"/></svg>'; // Show Pause icon when playing
                // Resume showing the current value
                const val = (state.frames && state.frames.length > 0) ? state.frames[state.playIdx] : (currentFaderValues[addr] || 0);
                updateDmxState(parseInt(addr), val, true, true);
            }
        }

        function looperTick() {
            Object.keys(looperState).forEach(addr => {
                const state = looperState[addr];
                if (state.mode === 'playing' && state.frames && state.frames.length > 0) {
                    state.playIdx = (state.playIdx + 1) % state.frames.length;
                    const val = state.frames[state.playIdx];
                    updateDmxState(parseInt(addr), val, true, true); // skipLinked, skipAutoCheck
                } else if (state.mode === 'paused') {
                    // Force 0 value when paused but skip UI update (keep showing entered range/val)
                    updateDmxState(parseInt(addr), 0, true, true, true); 
                }
            });
        }

