        // --- FIXTURE EDITOR ---
        async function loadProfileList() {
            const res = await fetch(API_BASE);
            const files = await res.json();
            availableProfiles = files.filter(f => f !== 'stage_config.json' && f !== 'presets.json' && f !== 'vibe_config.json' && f.endsWith('.json'));

            // Identify active profile types from stage config
            const activeTypes = new Set();
            Object.values(stageConfig.devices || {}).forEach(dev => {
                if (dev.type) activeTypes.add(dev.type.toLowerCase());
            });

            const sel = document.getElementById('profile-select');
            const quickList = document.getElementById('quick-profile-list');

            sel.innerHTML = '<option value="">-- Select Inactive Profile --</option>';
            if (quickList) quickList.innerHTML = '';

            // Separate active and inactive profiles
            const activeProfiles = [];
            const inactiveProfiles = [];

            availableProfiles.forEach(f => {
                const profileName = f.replace('.json', '');
                if (activeTypes.has(profileName.toLowerCase())) {
                    activeProfiles.push(f);
                } else {
                    inactiveProfiles.push(f);
                }
            });

            // Populate Inactive Profiles Dropdown
            inactiveProfiles.forEach(f => {
                const opt = document.createElement('option');
                opt.value = f;
                opt.innerText = f.replace('.json', '');
                sel.appendChild(opt);
            });

            // Populate Active Profiles Quick List
            if (quickList) {
                if (activeProfiles.length === 0) {
                    quickList.innerHTML = '<p style="text-align:center; color:var(--text-dim); font-size:12px; padding:20px;">No profiles currently active on stage.</p>';
                } else {
                    activeProfiles.forEach(f => {
                        const btn = document.createElement('button');
                        btn.className = 'card';
                        btn.style.textAlign = 'left';
                        btn.style.padding = '15px';
                        btn.style.cursor = 'pointer';
                        btn.style.marginBottom = '0';
                        btn.style.borderLeft = '4px solid var(--accent)';
                        btn.style.fontSize = '14px';
                        btn.style.fontWeight = 'bold';
                        btn.style.background = 'rgba(255,255,255,0.02)';
                        btn.style.color = 'white';
                        btn.innerText = f.replace('.json', '');
                        btn.onclick = () => {
                            sel.value = f;
                            loadFixtureProfile(f);
                        };
                        btn.onmouseover = () => btn.style.background = 'rgba(124, 77, 255, 0.1)';
                        btn.onmouseout = () => btn.style.background = 'rgba(255,255,255,0.02)';
                        quickList.appendChild(btn);
                    });
                }
            }

            // Re-render stage devices to populate dropdowns
            if (stageConfig.devices) renderDevices();
        }

        async function loadFixtureProfile(fname) {
            if (!fname) {
                document.getElementById('editor-container').style.display = 'none';
                document.getElementById('editor-empty-state').style.display = 'block';
                return;
            }

            const res = await fetch(`${API_BASE}/${fname}`);
            currentProfile = await res.json();

            document.getElementById('fix-filename').value = fname.replace('.json', '');
            document.getElementById('fix-type').value = currentProfile.type || '';
            document.getElementById('fix-name').value = currentProfile.name || '';
            syncUiToJson();

            document.getElementById('editor-container').style.display = 'block';
            document.getElementById('editor-empty-state').style.display = 'none';
            renderProfileUi();
        }

        async function saveFixtureProfile(silent = false) {
            try {
                // Sync basic info fields into currentProfile
                if (currentProfile) {
                    currentProfile.type = document.getElementById('fix-type').value;
                    currentProfile.name = document.getElementById('fix-name').value || (document.getElementById('fix-filename').value);
                }
                const data = currentProfile || JSON.parse(document.getElementById('json-editor').value);

                const fname = document.getElementById('fix-filename').value + '.json';

                const res = await fetch(`${API_BASE}/${fname}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data, null, 4)
                });
                if (!res.ok) throw new Error(`HTTP ${res.status}`);
                if (!silent) alert(`Saved ${fname}`);
                loadProfileList();
            } catch (e) {
                if (!silent) alert("Error saving JSON: " + e.message);
                console.error("Auto-save failed:", e);
            }
        }

        function tryAutoSave() {
            if (activeLiveTesters && Object.keys(activeLiveTesters).length > 0) {
