            await savePresetToDisk(presetName, {
                vibe: vibe.toLowerCase().trim(),
                trigger: trigger,
                target_fixtures: [...activeTestDevices],
                target_category: (primaryDev ? primaryDev.category : 'laser'),
                fixture_payloads: fixturePayloads
            });
        }

        async function savePresetToDisk(name, data) {
            console.log(`[DEBUG] Attempting to save preset: ${name}`, data);
            let existingPresets = {};
            try {
                const url = `${API_BASE}/presets.json?t=${Date.now()}`;
                console.log(`[DEBUG] Fetching existing presets from: ${url}`);
                const res = await fetch(url, { cache: 'no-store' });
                if (res.ok) {
                    existingPresets = await res.json();
                    console.log(`[DEBUG] Found ${Object.keys(existingPresets).length} existing presets`);
                } else {
                    console.warn(`[DEBUG] Could not fetch existing presets (HTTP ${res.status}), starting fresh.`);
                }
            } catch (e) {
                console.error(`[DEBUG] Error loading existing presets:`, e);
                // Continue with empty object if it's the first time or error
            }

            existingPresets[name] = data;

            try {
                console.log(`[DEBUG] Sending PUT request to: ${API_BASE}/presets.json`);
                const saveRes = await fetch(`${API_BASE}/presets.json`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(existingPresets, null, 4)
                });

                if (saveRes.ok) {
                    console.log(`[DEBUG] Save successful!`);
                    alert(`✅ Preset "${name}" saved!`);
                    await renderPresetsManager(true);
                } else {
                    const errText = await saveRes.text();
                    console.error(`[DEBUG] Save failed: HTTP ${saveRes.status}`, errText);
                    alert("❌ Error saving presets.json: " + errText);
                }
            } catch (e) {
                console.error(`[DEBUG] Network error during save:`, e);
                alert("❌ Connection error while saving presets: " + e.message);
            }
        }

