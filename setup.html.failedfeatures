        // ==================== SECTION VISIBILITY ====================
        function profileHasRolesFor(section) {
            const roles = Object.keys(currentProfile.channels || {});
            const modifiers = Object.values(currentProfile.modifiers || {});
            switch (section) {
                case 'step_data':
                    // Show if any role uses patterns/4th beat/beat mod OR if any channel is NAMED patterns
                    return roles.some(r => ROLES_WITH_STEPS.includes(r)) ||
                        modifiers.some(m => ['4th beat', 'beat'].includes(m));
                case 'macros': return roles.some(r => ROLE_MODES[r] && ROLE_MODES[r].length > 1);
                default: return true;
            }
        }

