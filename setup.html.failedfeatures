        // --- LIVE TEST ---
        function connectWs() {
            const host = localStorage.getItem('vj_backend_host') || 'api.ravebox.love';
            const wsProtocol = 'wss';
            const wsHost = (host === 'api.ravebox.love') ? 'wss.ravebox.love' : host;
            const wsUrl = (host === 'api.ravebox.love') ? `${wsProtocol}://${wsHost}` : `${wsProtocol}://${host}:8765`;
            ws = new WebSocket(wsUrl);
            ws.onopen = () => {
                document.getElementById('conn-status').innerHTML = '<span style="display:flex; align-items:center; gap:4px;"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg> Connected</span>';
                document.getElementById('conn-status').style.color = "var(--success)";

                // Request current system parameters to populate the Axis Matrix
                ws.send(JSON.stringify({ type: 'get_params' }));
            };
            ws.onmessage = (event) => {
                try {
                    const msg = JSON.parse(event.data);
                    if (msg.dmx) {
                        latestDmxState = msg.dmx;
                        if (isEngineVisualOn) {
                            updateTestFadersFromLive(msg.dmx);
                        }
                    }
                } catch (e) {
                    console.error("WS Parse Error:", e);
                }
            };
            ws.onclose = () => {
                document.getElementById('conn-status').innerHTML = '<span style="display:flex; align-items:center; gap:4px;"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg> Offline</span>';
                document.getElementById('conn-status').style.color = "var(--danger)";
                setTimeout(connectWs, 2000);
            };
        }

        function updateTestFadersFromLive(dmx) {
            // Only update sliders/values for the currently active test devices
            activeTestDevices.forEach(devName => {
                const dev = (stageConfig.devices || {})[devName];
                if (!dev) return;
                const profile = testProfiles[dev.type];
                if (!profile || !profile.channels) return;

                Object.entries(profile.channels).forEach(([role, val]) => {
                    const offset = typeof val === 'object' ? val.offset : val;
                    const absAddr = dev.address + dev.offset + offset;

                    // Mixed Control Mode: Skip updating sliders that are currently being manipulated or held
                    if (draggingAddresses.has(absAddr) || saveActiveChannels[absAddr]) return;

                    const dmxKey = `${devName}_${role}`;
                    const dmxVal = dmx[dmxKey];

                    if (dmxVal !== undefined) {
                        const input = document.getElementById(`input-${absAddr}`);
                        const disp = document.getElementById(`disp-${absAddr}`);
                        if (input) input.value = dmxVal;
                        if (disp) {
                            disp.value = dmxVal;
                            disp.innerText = dmxVal;
                        }
                        // Sync currentFaderValues to prevent snap-back when switching to manual mode
                        currentFaderValues[absAddr] = dmxVal;
                    }
                });
            });
        }

        function populateTestDevices() {
            const sel = document.getElementById('test-dev-select');
            if (!sel) return;
            const currentVal = sel.value;
            sel.innerHTML = '';

            let allDevices = stageConfig.devices || {};

            Object.keys(allDevices).forEach(k => {
                const opt = document.createElement('option');
                opt.value = k;
                opt.innerText = k;
                sel.appendChild(opt);
            });

            if (currentVal && Array.from(sel.options).some(o => o.value === currentVal)) {
                sel.value = currentVal;
            }

            if (sel.options.length > 0 && activeTestDevices.length === 0) {
                // Initialize with first device if none active
                handleDeviceSelection(sel.value);
            }
        }

